__pycache__/
*.pyc
.venv/
venv/
.env

# Downloaded PDFs are large binaries; download_manifest.json tracks what's there
data/raw/*.pdf

# Per-page parsed text is a build artifact of ingest.parse
data/interim/

# Chunked JSON is a build artifact of ingest.chunk, regenerable via
# ingest.download -> ingest.parse -> ingest.chunk
data/processed/*.json

# Local persistent ChromaDB store is a build artifact of retrieval.index
data/chroma/

# eval.run's incremental checkpoint is a resumable working file, not a
# result worth tracking — the dated JSON in eval/results/ is the deliverable.
eval/results/_checkpoint.json
